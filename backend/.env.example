# Backend environment variables
# Add your Gemini API key from Google AI Studio
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional alias supported by the code
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: force a specific model ID (use ListModels output if unsure)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: separate model for chat endpoint
# GEMINI_CHAT_MODEL=gemini-2.0-flash

# Optional server port
# PORT=5000

# Auth
# Used to sign JWT tokens for login. Set to a long random string.
JWT_SECRET=replace_with_a_long_random_secret
